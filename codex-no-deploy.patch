+# Optional: how often holdings are checked, in seconds.
+MONITOR_INTERVAL_SECONDS=900
+
+# Optional: enable a Telegram alive ping every 6 hours.
+ENABLE_ALIVE_PING=false
+
+# Optional: custom path for the local holdings baseline file.
+HOLDINGS_STATE_FILE=last_holdings.json
